cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.pnpm-store/
.yarn/

# Build outputs
dist/
build/
out/
*.tsbuildinfo
.next/
.expo/

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Prisma
prisma/dev.db
prisma/dev.db-journal

# Testing
coverage/

# React Native
ios/Pods/
ios/build/
android/.gradle/
android/build/
android/app/build/
*.keystore
!debug.keystore
.expo/
EOF